{
  "name": "dd-starter",
  "version": "1.0.0",
  "description": "Delmare Digital starter template for Payload CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "refresh-puck": "pnpm remove @delmaredigital/payload-puck && pnpm add @delmaredigital/payload-puck --registry http://localhost:4873",
    "refresh-ba": "pnpm remove @delmaredigital/payload-better-auth && pnpm add @delmaredigital/payload-better-auth --registry http://localhost:4873",
    "refresh-pagetree": "pnpm remove @delmaredigital/payload-page-tree && pnpm add @delmaredigital/payload-page-tree --registry http://localhost:4873",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "check": "pnpm exec tsc --noEmit && pnpm lint",
    "ci": "payload migrate && pnpm build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --experimental-https",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "eslint --cache --cache-location .next/cache/eslint/",
    "lint:fix": "eslint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation --import=./otel-bootstrap.mjs\" next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@better-auth/api-key": "^1.6.0",
    "@better-auth/passkey": "^1.6.0",
    "@chenglou/pretext": "^0.0.5",
    "@delmaredigital/payload-better-auth": "^0.5.6",
    "@delmaredigital/payload-page-tree": "0.3.13",
    "@delmaredigital/payload-puck": "^0.6.23",
    "@mcp-b/global": "^2.2.0",
    "@mcp-b/webmcp-types": "^2.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/instrumentation-pg": "^0.67.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@payloadcms/admin-bar": "^3.81.0",
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/live-preview-react": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-redirects": "^3.81.0",
    "@payloadcms/plugin-search": "^3.81.0",
    "@payloadcms/plugin-seo": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/storage-s3": "^3.81.0",
    "@payloadcms/ui": "^3.81.0",
    "@puckeditor/core": "^0.21.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tiptap/extension-color": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "entities": "^8.0.0",
    "geist": "^1.7.0",
    "graphql": "^16.13.2",
    "lucide-react": "^0.562.0",
    "next": "^16.2.2",
    "next-sitemap": "^4.2.3",
    "payload": "^3.81.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-opentelemetry-transport": "^3.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-arborist": "3.4.3",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "sonner": "2.0.7",
    "tailwind-merge": "^3.5.0",
    "tex-linebreak": "^0.8.1",
    "zod": "^4",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^26.1.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.0.0-rc.1+sha512.0d7d837668eb35b81d28f560ef8ec5e103ff5d162e249fd0d30c546c39a551d290ac9cf15709353b94d2df6eb445bfa465c7a05148d328eda32950c02e40d060",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "patchedDependencies": {
      "@delmaredigital/payload-puck": "patches/@delmaredigital__payload-puck.patch"
    }
  }
}
